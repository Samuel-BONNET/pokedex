generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

model User {
  id            Int         @id @default(autoincrement())
  pseudo        String      @db.VarChar(50)
  email         String      @db.VarChar(50) @unique
  password      String
  role          String      @db.VarChar(50)
  isActive      Boolean     @default(true)
  preferences   Json        @db.JsonB
  createdAt     DateTime    @default(now())
  statuts       Statut[]
}

model Game {
    id          Int       @id @default(autoincrement())
    nameEn      String    @db.VarChar(50) @unique
    generation  Int
    currentJaquette String
    statuts     Statut[]
}

model Pokemon {
    id              Int     @id @default(autoincrement())
    nameFr          String  @db.VarChar(50)
    nameEn          String  @db.VarChar(50)
    pokeNumber      Int     @unique
    availableGames  Json
    statuts         Statut[]
}

model Statut {
  idPokemon           Int
  idUser              Int
  idGameProvenance    Int

  user                User        @relation(fields: [idUser], references: [id])
  pokemon             Pokemon     @relation(fields: [idPokemon], references: [id])
  game                Game        @relation(fields: [idGameProvenance], references: [id])

  isOwned             Boolean
  isShiny             Boolean
  currentSprite       String

  @@id([idPokemon, idUser])
}